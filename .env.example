# Copy this file to ".env" and fill in your values. NEVER commit the real .env.

# Your Anthropic API key (get it at console.anthropic.com). Used server-side only.
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx

# Which Claude model the chat assistant (Jackie, text mode) uses.
CLAUDE_MODEL=claude-sonnet-4-20250514

# ---------------------------------------------------------------------------
# JACKIE VOICE (optional) — live spoken assistant via OpenAI's Realtime API.
# Leave OPENAI_API_KEY blank to keep Jackie text-only (the mic button then
# shows a friendly "voice isn't set up" message). Must be a real OpenAI key
# (sk-...), NOT an OpenRouter key — only OpenAI can open a realtime session.
# ---------------------------------------------------------------------------
OPENAI_API_KEY=
# Realtime model + voice (defaults are fine). Voices: alloy, shimmer, echo, etc.
OPENAI_REALTIME_MODEL=gpt-realtime
OPENAI_REALTIME_VOICE=shimmer

# A secret you choose. Required to view/export/delete leads in the CRM.
# Make it long and random.
ADMIN_KEY=change-me-to-a-long-random-string

# Port (Railway sets this automatically; leave blank locally to use 3000).
PORT=

# Where the lead database lives. On Railway, set this to your mounted
# volume path (e.g. /data) so leads persist across deploys.
DATA_DIR=

# ---------------------------------------------------------------------------
# EMAIL NOTIFICATIONS (optional, self-hosted SMTP — no third-party CRM/ESP).
# When a new lead comes in, the owner gets an email. Leave SMTP_HOST or
# LEAD_NOTIFY_TO blank to turn notifications off (the site still runs fine).
# Works with any SMTP provider (Gmail app password, Fastmail, Mailgun SMTP,
# your own postfix, etc.).
# ---------------------------------------------------------------------------
SMTP_HOST=
SMTP_PORT=587
# secure=true for port 465 (implicit TLS); leave blank to auto-pick (true for 465).
SMTP_SECURE=
SMTP_USER=
SMTP_PASS=

# Who receives the "new lead" alerts (your inbox).
LEAD_NOTIFY_TO=
# The From address shown on the alert (defaults to LEAD_NOTIFY_TO if blank).
LEAD_NOTIFY_FROM=

# Public URL of the CRM, used for the "Open the CRM" button in the email.
# e.g. https://ecdkangen.com/admin
ADMIN_URL=
